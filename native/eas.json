{
  // -------------------------------------------------------------------------
  // OPERATOR CHECKLIST — fill these before running `eas submit`:
  //
  //   submit.production.ios.appleId     — Apple ID email of the app-manager
  //                                       role account (not personal Apple ID)
  //   submit.production.ios.ascAppId    — App Store Connect numeric App ID;
  //                                       found under App Store Connect →
  //                                       App Information → Apple ID field
  //   submit.production.ios.appleTeamId — 10-char Team ID from
  //                                       developer.apple.com → Account →
  //                                       Membership Details
  //
  //   submit.production.android.serviceAccountKeyPath
  //                                    — path to the Google Play service
  //                                       account JSON (never commit this
  //                                       file; add to .gitignore +
  //                                       .easignore)
  //
  // NOTE: appVersionSource "remote" means EAS owns build number / versionCode
  // auto-increment. Never manually edit buildNumber or versionCode in
  // app.json again — EAS will override them at build time.
  // -------------------------------------------------------------------------
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8000/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "resourceClass": "m-medium",
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.joincompasschw.com/api/v1"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "distribution": "store",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.joincompasschw.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "OPERATOR_APPLE_ID",
        "ascAppId": "OPERATOR_ASC_APP_ID",
        "appleTeamId": "OPERATOR_APPLE_TEAM_ID",
        "language": "en-US"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
