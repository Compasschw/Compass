# vite-plugin-pwa@1.2.0 declares a stale peer-dependency range for vite that
# excludes vite@7.x even though it works fine in practice. npm@7+ rejects the
# install with ERESOLVE; legacy-peer-deps mirrors npm@6 behaviour and accepts.
# Drop this file once vite-plugin-pwa publishes a release that accepts vite@7.
legacy-peer-deps=true
