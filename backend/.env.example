# backend/.env.example
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://compass:YOUR_PASSWORD@localhost:5432/compass

# Security
SECRET_KEY=  # REQUIRED (min 32 chars) — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=   # REQUIRED (min 16 chars) — generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
PHI_ENCRYPTION_KEY=  # 32 random bytes, base64 — generate with: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"

# AWS
AWS_REGION=us-west-2
S3_BUCKET_PHI=compass-phi-dev
S3_BUCKET_PUBLIC=compass-public-dev

# Call recording / transcript / AI-summary buckets (Phase 1 audio architecture)
# Set these in production after creating the buckets via docs/runbooks/create-phi-buckets.md
S3_CALL_RECORDINGS_BUCKET=
S3_TRANSCRIPTS_BUCKET=
S3_AI_SUMMARIES_BUCKET=
# PHI bucket for message attachments (images + PDFs shared in CHW↔member chat).
# Create via docs/runbooks/create-phi-buckets.md → Step 3b before setting this.
S3_MESSAGE_ATTACHMENTS_BUCKET=compass-prod-message-attachments
# PHI bucket for member-owned documents (government IDs, income proof, etc.).
# Create via docs/runbooks/create-phi-buckets.md → Step 3c before setting this.
S3_MEMBER_DOCUMENTS_BUCKET=compass-prod-member-documents
# ARN of the KMS key used for SSE-KMS on all five PHI buckets.
# Format: arn:aws:kms:us-west-2:{account_id}:key/{key_id}
S3_KMS_KEY_ARN=

# CORS
CORS_ORIGINS=["http://localhost:5173","https://joincompasschw.com"]

# Communication provider (vonage, twilio, plivo)
COMMUNICATION_PROVIDER=vonage

# Vonage (recommended for MVP)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY_PATH=

# Twilio (future option)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=

# Pear Suite billing integration
PEAR_SUITE_API_KEY=
PEAR_SUITE_BASE_URL=https://api.pearsuite.com

# Notification provider (expo | direct_apns | direct_fcm)
NOTIFICATION_PROVIDER=expo
EXPO_ACCESS_TOKEN=   # Optional; higher rate limits when set

# Email provider (ses default; covered by AWS BAA)
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@joincompasschw.com
EMAIL_REPLY_TO=   # Optional; leave blank to disable

# Magic-link (passwordless email login)
MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_BASE_URL=https://joincompasschw.com/auth/magic

# Transcription provider (assemblyai | vonage_builtin)
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=

# Observability
SENTRY_DSN=
ENVIRONMENT=development   # development | staging | production

# Payments (Stripe Connect Express)
PAYMENTS_PROVIDER=stripe
STRIPE_SECRET_KEY=   # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=   # whsec_... from https://dashboard.stripe.com/webhooks
STRIPE_PLATFORM_NAME=CompassCHW
